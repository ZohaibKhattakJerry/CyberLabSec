generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Applicant {
  id               String            @id @default(cuid())
  fullName         String
  email            String
  phone            String
  city             String?
  cnicEncrypted    String
  cnicHash         String            @unique
  cvFileUrl        String
  photoUrl         String?
  linkedIn         String?
  github           String?
  tryHackMe        String?
  hackTheBox       String?
  portfolio        String?
  cve              String?
  certifications   String?
  motivation       String?
  portfolioLinks   String            @default("[]")
  universityName   String?
  semester         String?
  jobPostingId     String
  status           String            @default("Applied") // Applied, Screening, Interview, Final Approval, Offer, Hired, Rejected, Withdrawn
  fitScore         Int?
  fitReasoning     String?
  internalRating   Int?
  privateNotes     String?
  consentData      String            @default("{}")
  ipAddress        String?
  emailVerified    Boolean           @default(false)
  referenceId      String?           @unique
  screeningAnswers   String            @default("{}")
  bugBountyProfile   String?
  reviewerRating     Int?
  reviewerScorecard  String            @default("{}")
  stageHistory       String            @default("[]")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  jobPosting       JobPosting        @relation(fields: [jobPostingId], references: [id])
  employeeRecord   Employee?
  interviewSession InterviewSession?
  ceoReviews       CEOReview[]
  offerLetter      OfferLetter?
}

model JobPosting {
  id                 String      @id @default(cuid())
  title              String
  type               String
  department         String
  location           String
  description        String
  requirements       String
  universityRequired Boolean     @default(false)
  deadline           DateTime
  status             String      @default("Draft") // Draft, Published, Paused, Closed
  shortlistThreshold Int         @default(50)
  passMark           Int         @default(60)
  showApplicantCount Boolean     @default(false)
  niceToHave         String?
  whatYouGain        String?
  screeningQuestions String      @default("[]")
  stipend            String?
  showStipend        Boolean     @default(true)
  duration           String?
  weeklyHours        Int?
  experienceLevel    String      @default("Any")
  openings           Int         @default(1)
  autoShortlist      Boolean     @default(true)
  assessmentSettings String      @default("{}")
  assessmentBank     String      @default("[]")
  answerKey          String      @default("{}")
  publishedDate      DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  applicants         Applicant[]
  offerLetters       OfferLetter[]
}

model InterviewSession {
  id                  String    @id @default(cuid())
  applicantId         String    @unique
  token               String    @unique
  tokenExpiry         DateTime
  tokenUsed           Boolean   @default(false)
  emailVerified       Boolean   @default(false)
  questions           String    @default("[]")
  answers             String    @default("[]")
  perQuestionScore    String    @default("[]")
  cheatingSignals     String    @default("{}")
  integrityViolations String    @default("[]")
  attempts            Int       @default(0)
  maxAttempts         Int       @default(3)
  totalScore          Int?
  autoScore           Int?
  reviewerNotes       String?
  result              String?
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime  @default(now())
  applicant           Applicant @relation(fields: [applicantId], references: [id])
}

model Employee {
  id                   String                    @id @default(cuid())
  employeeCode         String                    @unique
  name                 String
  email                String                    @unique
  photoUrl             String?
  designation          String
  employmentType       String
  tier                 String                    @default("Standard") // Standard, Lead, Executive
  startDate            DateTime
  endDate              DateTime?
  status               String                    @default("Active")
  teamId               String?
  passwordHash         String
  mustResetPassword    Boolean                   @default(true)
  forcePasswordChange  Boolean                   @default(true)
  resetToken           String?                   @unique
  resetTokenExpiry     DateTime?
  policyAcknowledgedAt DateTime?
  onboardingCompleted  Boolean                   @default(false)
  githubUrl            String?
  linkedinUrl          String?
  phone                String?
  personalEmail        String?
  address              String?
  emergencyContact     String?
  skills               String                    @default("[]")
  offboardedAt         DateTime?
  offboardReason       String?
  customCertificateUrl String?
  customLorUrl         String?
  points               Int                       @default(0)
  monthlyPoints        Int                       @default(0)
  applicantId          String?                   @unique
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  activityLogs         ActivityLog[]
  announcementsRecv    Announcement[]            @relation("ReceivedAnnouncements")
  announcementsSent    Announcement[]            @relation("SentBy")
  applicant            Applicant?                @relation(fields: [applicantId], references: [id])
  team                 Team?                     @relation(fields: [teamId], references: [id])
  submissions          TaskSubmission[]          @relation("EmployeeSubmissions")
  messages             TeamMessage[]
  submittedReviews     CEOReview[]               @relation("ReviewSubmitter")
  announcementReads    AnnouncementReadReceipt[]
  badges               Badge[]
  pointTransactions    PointTransaction[]
  supportTickets       SupportTicket[]
  attendanceRecords    AttendanceRecord[]
  leaveRequests        LeaveRequest[]
  proposedMeetings     MeetingRequest[]          @relation("MeetingProposer")
  appraisalsReceived   PerformanceAppraisal[]    @relation("AppraisalSubject")
  appraisalsGiven      PerformanceAppraisal[]    @relation("AppraisalReviewer")
  documents            EmployeeDocument[]
}

model Team {
  id             String         @id @default(cuid())
  name           String
  leadEmployeeId String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  announcements   Announcement[]
  members         Employee[]
  tasks           Task[]
  messages        TeamMessage[]
  meetingRequests MeetingRequest[]
}

model Task {
  id              String           @id @default(cuid())
  teamId          String
  title           String
  brief           String
  category        String           @default("General")
  deliverableType String           @default("Any") // File, Text, Link, Any
  attachments     String           @default("[]")
  deadline        DateTime
  createdBy       String
  priority        String           @default("Medium")
  status          String           @default("Assigned")
  assigneeId      String?
  checklist       String           @default("[]")
  comments        String           @default("[]")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  team            Team             @relation(fields: [teamId], references: [id])
  submissions     TaskSubmission[]
}

model TaskSubmission {
  id               String   @id @default(cuid())
  taskId           String
  employeeId       String
  textResponse     String?
  linkResponse     String?
  files            String   @default("[]")
  status           String   @default("Pending") // Pending, Under Review, Needs Revision, Approved
  reviewerFeedback String?
  reviewerScore    Int?
  aiSummary        String?
  submittedAt             DateTime  @default(now())
  version                 Int       @default(1)
  summary                 String?
  reviewedAt              DateTime?
  qualityRating           Int?
  reviewerFeedbackHistory String    @default("[]")
  employee                Employee  @relation("EmployeeSubmissions", fields: [employeeId], references: [id], onDelete: Cascade)
  task                    Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, employeeId])
}

model Announcement {
  id         String                    @id @default(cuid())
  scope      String
  teamId     String?
  employeeId String?
  message    String
  isPinned   Boolean                   @default(false)
  expiresAt  DateTime?
  sentById   String
  sentAt     DateTime                  @default(now())
  employee   Employee?                 @relation("ReceivedAnnouncements", fields: [employeeId], references: [id])
  sentBy     Employee                  @relation("SentBy", fields: [sentById], references: [id])
  team       Team?                     @relation(fields: [teamId], references: [id])
  reads      AnnouncementReadReceipt[]
}

model AnnouncementReadReceipt {
  id             String       @id @default(cuid())
  announcementId String
  employeeId     String
  readAt         DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  employee       Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([announcementId, employeeId])
}

model CEOReview {
  id          String     @id @default(cuid())
  type        String // e.g. Hire, Promotion
  submitterId String
  applicantId String?
  status      String     @default("Pending") // Pending, Approved, Rejected, More Info
  comments    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  submitter   Employee   @relation("ReviewSubmitter", fields: [submitterId], references: [id])
  applicant   Applicant? @relation(fields: [applicantId], references: [id])
}

model OfferLetter {
  id            String      @id @default(cuid())
  applicantId   String      @unique
  jobPostingId  String?
  content       String
  status        String      @default("Sent")
  expiresAt     DateTime
  viewedAt      DateTime?
  acceptedAt    DateTime?
  declinedAt    DateTime?
  acceptedName  String?
  acceptedIp    String?
  declineReason String?
  token         String      @unique
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  applicant     Applicant   @relation(fields: [applicantId], references: [id])
  jobPosting    JobPosting? @relation(fields: [jobPostingId], references: [id])
}

model EmployeeDocument {
  id           String    @id @default(cuid())
  employeeId   String
  title        String
  type         String    @default("General") // Offer Letter, Contract, ID, Request, etc
  fileUrl      String?
  status       String    @default("Uploaded") // Uploaded, Requested, Approved, Rejected
  uploadedBy   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String    @id @default(cuid())
  actorId   String?
  actorType String
  action    String
  metadata  String    @default("{}")
  ipAddress String?
  timestamp DateTime  @default(now())
  employee  Employee? @relation(fields: [actorId], references: [id], onDelete: Cascade)
}

model PolicyDocument {
  id        String   @id @default(cuid())
  title     String
  body      String
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamMessage {
  id         String   @id @default(cuid())
  teamId     String
  employeeId String
  message    String
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id])
  team       Team     @relation(fields: [teamId], references: [id])
}

model Badge {
  id         String   @id @default(cuid())
  employeeId String
  type       String
  label      String
  awardedAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, type])
}

model PointTransaction {
  id          String   @id @default(cuid())
  employeeId  String
  taskId      String?
  points      Int
  reason      String
  adjustedBy  String?
  createdAt   DateTime @default(now())
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model AdminConfig {
  id        String   @id @default("singleton")
  data      String   @default("{}")
  updatedAt DateTime @updatedAt
}

model RateLimit {
  id        String   @id @default(cuid())
  key       String   @unique
  attempts  Int      @default(0)
  resetAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model EmailVerification {
  id        String   @id @default(cuid())
  email     String   @unique
  otp       String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
}



model TalentPool {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model SupportTicket {
  id           String    @id @default(cuid())
  employeeId   String
  category     String    @default("General")
  title        String
  description  String
  priority     String    @default("Medium")
  status       String    @default("Open")
  response     String?
  respondedBy  String?
  respondedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model AttendanceRecord {
  id          String    @id @default(cuid())
  employeeId  String
  date        DateTime  @db.Date
  loginTime   DateTime  @default(now())
  logoutTime  DateTime?
  status      String    @default("Present")
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([employeeId])
}

model LeaveRequest {
  id           String    @id @default(cuid())
  employeeId   String
  type         String
  startDate    DateTime  @db.Date
  endDate      DateTime  @db.Date
  totalDays    Int       @default(1)
  reason       String
  status       String    @default("Pending")
  reviewedBy   String?
  reviewerNote String?
  reviewedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model MeetingRequest {
  id             String    @id @default(cuid())
  teamId         String
  proposedBy     String
  title          String
  description    String?
  proposedTimes  String    @default("[]")
  votes          String    @default("{}")
  confirmedTime  DateTime?
  meetingLink    String?
  status         String    @default("Voting")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  team           Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  proposer       Employee  @relation("MeetingProposer", fields: [proposedBy], references: [id])
}


model PerformanceAppraisal {
  id           String    @id @default(cuid())
  employeeId   String
  reviewerId   String
  period       String
  rating       Int       
  feedback     String
  status       String    @default("Draft")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  employee     Employee  @relation("AppraisalSubject", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewer     Employee  @relation("AppraisalReviewer", fields: [reviewerId], references: [id])
}
