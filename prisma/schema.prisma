generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Applicant {
  id               String           @id @default(cuid())
  fullName         String
  email            String
  phone            String
  cnicEncrypted    String
  cnicHash         String           @unique
  cvFileUrl        String
  photoUrl         String?
  portfolioLinks   String           @default("[]") // JSON string
  universityName   String?
  semester         String?
  jobPostingId     String
  jobPosting       JobPosting       @relation(fields: [jobPostingId], references: [id])
  status           String           @default("Applied") // ApplicantStatus enum
  fitScore         Int?
  fitReasoning     String?
  interviewSession InterviewSession?
  consentData      String           @default("{}") // JSON string
  ipAddress        String?
  employeeRecord   Employee?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model JobPosting {
  id                 String      @id @default(cuid())
  title              String
  type               String      // "Job" | "Internship"
  department         String
  location           String
  description        String
  requirements       String
  universityRequired Boolean     @default(false)
  deadline           DateTime
  status             String      @default("Open") // "Open" | "Closed"
  shortlistThreshold Int         @default(50)
  passMark           Int         @default(60)
  applicants         Applicant[]
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
}

model InterviewSession {
  id              String    @id @default(cuid())
  applicantId     String    @unique
  applicant       Applicant @relation(fields: [applicantId], references: [id])
  token           String    @unique
  tokenExpiry     DateTime
  tokenUsed       Boolean   @default(false)
  emailVerified   Boolean   @default(false)
  questions       String    @default("[]") // JSON
  answers         String    @default("[]") // JSON
  perQuestionScore String   @default("[]") // JSON
  cheatingSignals  String   @default("{}") // JSON
  totalScore      Int?
  result          String?   // "Passed" | "Failed" | "Cheating"
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
}

model Employee {
  id                   String           @id @default(cuid())
  employeeCode         String           @unique
  name                 String
  email                String           @unique
  photoUrl             String?
  designation          String
  employmentType       String           // "Employee" | "Intern"
  startDate            DateTime
  endDate              DateTime?
  status               String           @default("Active") // "Active" | "Terminated"
  teamId               String?
  team                 Team?            @relation(fields: [teamId], references: [id])
  passwordHash         String
  mustResetPassword    Boolean          @default(true)
  policyAcknowledgedAt DateTime?
  onboardingCompleted  Boolean          @default(false)
  githubUrl            String?
  linkedinUrl          String?
  applicantId          String?          @unique
  applicant            Applicant?       @relation(fields: [applicantId], references: [id])
  submissions          TaskSubmission[]
  announcementsSent    Announcement[]   @relation("SentBy")
  announcementsRecv    Announcement[]   @relation("ReceivedAnnouncements")
  activityLogs         ActivityLog[]
  messages             TeamMessage[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
}

model Team {
  id              String        @id @default(cuid())
  name            String
  leadEmployeeId  String?
  members         Employee[]
  tasks           Task[]
  announcements   Announcement[]
  messages        TeamMessage[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Task {
  id          String           @id @default(cuid())
  teamId      String
  team        Team             @relation(fields: [teamId], references: [id])
  title       String
  brief       String
  attachments String           @default("[]") // JSON
  deadline    DateTime
  createdBy   String
  submissions TaskSubmission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model TaskSubmission {
  id          String   @id @default(cuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id])
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  files       String   @default("[]") // JSON
  status      String   @default("Pending") // "Pending" | "Approved" | "Revision"
  aiSummary   String?
  submittedAt DateTime @default(now())

  @@unique([taskId, employeeId])
}

model Announcement {
  id        String    @id @default(cuid())
  scope     String    // "Company" | "Team" | "Individual"
  teamId    String?
  team      Team?     @relation(fields: [teamId], references: [id])
  employeeId String?  
  employee  Employee? @relation("ReceivedAnnouncements", fields: [employeeId], references: [id])
  message   String
  isPinned  Boolean   @default(false)
  expiresAt DateTime?
  sentById  String
  sentBy    Employee  @relation("SentBy", fields: [sentById], references: [id])
  sentAt    DateTime  @default(now())
}

model ActivityLog {
  id         String    @id @default(cuid())
  actorId    String?
  actorType  String    // "Employee" | "System" | "Admin" | "Public"
  action     String
  metadata   String    @default("{}") // JSON
  timestamp  DateTime  @default(now())
  employee   Employee? @relation(fields: [actorId], references: [id])
}

model PolicyDocument {
  id        String   @id @default(cuid())
  title     String
  body      String
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamMessage {
  id         String   @id @default(cuid())
  teamId     String
  team       Team     @relation(fields: [teamId], references: [id])
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  message    String
  createdAt  DateTime @default(now())
}

model AdminConfig {
  id    String @id @default("singleton")
  data  String @default("{}") // JSON config blob
  updatedAt DateTime @updatedAt
}

model RateLimit {
  id        String   @id @default(cuid())
  key       String   @unique // IP or CNIC hash
  attempts  Int      @default(0)
  resetAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   // Employee ID or "admin"
  title     String
  message   String
  type      String   // "Task" | "Alert" | "System"
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
