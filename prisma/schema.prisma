generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Applicant {
  id               String            @id @default(cuid())
  fullName         String
  email            String
  phone            String
  cnicEncrypted    String
  cnicHash         String            @unique
  cvFileUrl        String
  photoUrl         String?
  portfolioLinks   String            @default("[]")
  universityName   String?
  semester         String?
  jobPostingId     String
  status           String            @default("Applied")
  fitScore         Int?
  fitReasoning     String?
  consentData      String            @default("{}")
  ipAddress        String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  jobPosting       JobPosting        @relation(fields: [jobPostingId], references: [id])
  employeeRecord   Employee?
  interviewSession InterviewSession?
}

model JobPosting {
  id                 String      @id @default(cuid())
  title              String
  type               String
  department         String
  location           String
  description        String
  requirements       String
  universityRequired Boolean     @default(false)
  deadline           DateTime
  status             String      @default("Open")
  shortlistThreshold Int         @default(50)
  passMark           Int         @default(60)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  applicants         Applicant[]
}

model InterviewSession {
  id               String    @id @default(cuid())
  applicantId      String    @unique
  token            String    @unique
  tokenExpiry      DateTime
  tokenUsed        Boolean   @default(false)
  emailVerified    Boolean   @default(false)
  questions        String    @default("[]")
  answers          String    @default("[]")
  perQuestionScore String    @default("[]")
  cheatingSignals  String    @default("{}")
  totalScore       Int?
  result           String?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  applicant        Applicant @relation(fields: [applicantId], references: [id])
}

model Employee {
  id                   String           @id @default(cuid())
  employeeCode         String           @unique
  name                 String
  email                String           @unique
  photoUrl             String?
  designation          String
  employmentType       String
  startDate            DateTime
  endDate              DateTime?
  status               String           @default("Active")
  teamId               String?
  passwordHash         String
  mustResetPassword    Boolean          @default(true)
  policyAcknowledgedAt DateTime?
  onboardingCompleted  Boolean          @default(false)
  githubUrl            String?
  linkedinUrl          String?
  applicantId          String?          @unique
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  activityLogs         ActivityLog[]
  announcementsRecv    Announcement[]   @relation("ReceivedAnnouncements")
  announcementsSent    Announcement[]   @relation("SentBy")
  applicant            Applicant?       @relation(fields: [applicantId], references: [id])
  team                 Team?            @relation(fields: [teamId], references: [id])
  submissions          TaskSubmission[]
  messages             TeamMessage[]
}

model Team {
  id             String         @id @default(cuid())
  name           String
  leadEmployeeId String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  announcements  Announcement[]
  members        Employee[]
  tasks          Task[]
  messages       TeamMessage[]
}

model Task {
  id          String           @id @default(cuid())
  teamId      String
  title       String
  brief       String
  attachments String           @default("[]")
  deadline    DateTime
  createdBy   String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  team        Team             @relation(fields: [teamId], references: [id])
  submissions TaskSubmission[]
}

model TaskSubmission {
  id          String   @id @default(cuid())
  taskId      String
  employeeId  String
  files       String   @default("[]")
  status      String   @default("Pending")
  aiSummary   String?
  submittedAt DateTime @default(now())
  employee    Employee @relation(fields: [employeeId], references: [id])
  task        Task     @relation(fields: [taskId], references: [id])

  @@unique([taskId, employeeId])
}

model Announcement {
  id         String    @id @default(cuid())
  scope      String
  teamId     String?
  employeeId String?
  message    String
  isPinned   Boolean   @default(false)
  expiresAt  DateTime?
  sentById   String
  sentAt     DateTime  @default(now())
  employee   Employee? @relation("ReceivedAnnouncements", fields: [employeeId], references: [id])
  sentBy     Employee  @relation("SentBy", fields: [sentById], references: [id])
  team       Team?     @relation(fields: [teamId], references: [id])
}

model ActivityLog {
  id        String    @id @default(cuid())
  actorId   String?
  actorType String
  action    String
  metadata  String    @default("{}")
  timestamp DateTime  @default(now())
  employee  Employee? @relation(fields: [actorId], references: [id])
}

model PolicyDocument {
  id        String   @id @default(cuid())
  title     String
  body      String
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamMessage {
  id         String   @id @default(cuid())
  teamId     String
  employeeId String
  message    String
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id])
  team       Team     @relation(fields: [teamId], references: [id])
}

model AdminConfig {
  id        String   @id @default("singleton")
  data      String   @default("{}")
  updatedAt DateTime @updatedAt
}

model RateLimit {
  id        String   @id @default(cuid())
  key       String   @unique
  attempts  Int      @default(0)
  resetAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
