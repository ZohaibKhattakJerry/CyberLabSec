# Environment Variables — CyberLabSec Ops Platform
# Copy this to .env and fill in your actual values.
# NEVER commit .env to git.

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# SMTP Email (send from contact@cyberlabsec.tech)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=contact@cyberlabsec.tech
SMTP_PASSWORD=your_smtp_password_here

# Auth
JWT_SECRET=your_jwt_secret_here

# Database
DATABASE_URL=postgres://user:password@host/db

# CNIC Encryption (32-char AES-256 key)
CNIC_ENCRYPTION_KEY=your_cnic_encryption_key_here

# App URL (update for production)
NEXTAUTH_URL=https://cyberlabsec.tech
